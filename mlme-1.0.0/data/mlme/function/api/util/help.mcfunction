tellraw @s ["",{"text":"  function mlme:api/hook/bind","color":"gray"}]
tellraw @s ["",{"text":"  Supported: player_join, player_death","color":"dark_gray"}]
tellraw @s ["",{"text":"--- Fiber ---","color":"yellow"}]
tellraw @s ["",{"text":"  data modify storage mlme:input fiber.id         set value \"my_fiber\"","color":"white"}]
