# PUBLIC API -- mlme:api/util/help
# macroLessMacroEngine v1.0.0

tellraw @s ["",{"text":"=== MLME v1.0.0 ===","color":"gold"}]
tellraw @s ["",{"text":"macroLessMacroEngine -- macro-free command engine","color":"gray"}]
tellraw @s ["",{"text":"--- Run ---","color":"yellow"}]
tellraw @s ["",{"text":"  data modify storage mlme:cmd Command set value \"<cmd>\"","color":"white"}]
tellraw @s ["",{"text":"  function mlme:api/run/cmd","color":"gray"}]
tellraw @s ["",{"text":"--- Run As Entity ---","color":"yellow"}]
tellraw @s ["",{"text":"  tag <selector> add mlme.executor","color":"white"}]
tellraw @s ["",{"text":"  data modify storage mlme:cmd Command set value \"<cmd>\"","color":"white"}]
tellraw @s ["",{"text":"  function mlme:api/run/as","color":"gray"}]
tellraw @s ["",{"text":"--- Queue ---","color":"yellow"}]
tellraw @s ["",{"text":"  data modify storage mlme:cmd Command set value \"<cmd>\"","color":"white"}]
tellraw @s ["",{"text":"  function mlme:api/queue/add   (repeat for each command)","color":"gray"}]
tellraw @s ["",{"text":"  function mlme:api/queue/run   (start)","color":"gray"}]
tellraw @s ["",{"text":"  function mlme:api/queue/clear (cancel)","color":"gray"}]
tellraw @s ["",{"text":"--- Batch ---","color":"yellow"}]
tellraw @s ["",{"text":"  data modify storage mlme:batch commands set value [\"<cmd1>\",\"<cmd2>\",...]","color":"white"}]
tellraw @s ["",{"text":"  function mlme:api/batch/run              (queue and run)","color":"gray"}]
tellraw @s ["",{"text":"  function mlme:api/batch/clear            (discard)","color":"gray"}]
tellraw @s ["",{"text":"--- Schedule ---","color":"yellow"}]
tellraw @s ["",{"text":"  data modify storage mlme:cmd Command set value \"<cmd>\"","color":"white"}]
tellraw @s ["",{"text":"  data modify storage mlme:cmd Delay set value <ticks>","color":"white"}]
tellraw @s ["",{"text":"  function mlme:api/schedule/run           (queue for later)","color":"gray"}]
tellraw @s ["",{"text":"  function mlme:api/schedule/clear         (cancel all)","color":"gray"}]
tellraw @s ["",{"text":"--- Cooldown ---","color":"yellow"}]
tellraw @s ["",{"text":"  data modify storage mlme:cd Ticks set value 100","color":"white"}]
tellraw @s ["",{"text":"  function mlme:api/cooldown/set           (start cooldown @s)","color":"gray"}]
tellraw @s ["",{"text":"  function mlme:api/cooldown/check         (1.20.2+: if function)","color":"gray"}]
tellraw @s ["",{"text":"  function mlme:api/cooldown/get           (-> mlme:output Cooldown.remaining)","color":"gray"}]
tellraw @s ["",{"text":"  function mlme:api/cooldown/clear         (clear @s cooldown)","color":"gray"}]
tellraw @s ["",{"text":"--- Hook / Event ---","color":"yellow"}]
tellraw @s ["",{"text":"  data modify storage mlme:input event set value \"player_join\"","color":"white"}]
